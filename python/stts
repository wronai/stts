def _yaml_fmt_scalar(v: Any) -> str:
    if v is None:
        return "null"
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, (int, float)):
        return str(v)
    s = str(v)
    if s == "":
        return "\"\""
    needs_quote = any(ch.isspace() for ch in s) or any(ch in s for ch in (":", "#", "\"", "'"))
    if needs_quote:
        s2 = s.replace("\\", "\\\\").replace("\"", "\\\"")
        return f"\"{s2}\""
    return s


def build_startup_yaml(config: dict) -> str:
    stt_provider = config.get("stt_provider")
    stt_model = config.get("stt_model")
    tts_provider = config.get("tts_provider")
    tts_voice = config.get("tts_voice")

    mic_cfg = config.get("mic_device")
    speaker_cfg = config.get("speaker_device")
    audio_auto_switch = config.get("audio_auto_switch")

    mic_cfg_v = "auto" if mic_cfg in (None, "", "auto") else mic_cfg
    speaker_cfg_v = "auto" if speaker_cfg in (None, "", "auto") else speaker_cfg

    pulse_src = None
    pulse_sink = None
    try:
        if platform.system().lower() == "linux":
            pulse_src, pulse_sink = get_active_pulse_devices()
    except Exception:
        pulse_src, pulse_sink = None, None

    lines = [
        "selected_models:",
        "  stt:",
        f"    provider: {_yaml_fmt_scalar(stt_provider)}",
        f"    model: {_yaml_fmt_scalar(stt_model)}",
        "  tts:",
        f"    provider: {_yaml_fmt_scalar(tts_provider)}",
        f"    voice: {_yaml_fmt_scalar(tts_voice)}",
        "io:",
        "  input:",
        "    - type: microphone",
        f"      config: {_yaml_fmt_scalar(mic_cfg_v)}",
        f"      pulse_default_source: {_yaml_fmt_scalar(pulse_src)}",
        "  output:",
        "    - type: speaker",
        f"      config: {_yaml_fmt_scalar(speaker_cfg_v)}",
        f"      pulse_default_sink: {_yaml_fmt_scalar(pulse_sink)}",
        f"  audio_auto_switch: {_yaml_fmt_scalar(audio_auto_switch)}",
    ]
    return "\n".join(lines) + "\n"


def emit_startup_yaml(config: dict) -> None:
    try:
        v = os.environ.get("STTS_STARTUP_YAML", "1").strip().lower()
        if v in ("0", "false", "no", "n"):
            return
        if _yaml_mode():
            out = sys.__stdout__
        else:
            force_stdout = os.environ.get("STTS_STARTUP_YAML_STDOUT", "0").strip().lower() in ("1", "true", "yes", "y")
            out = sys.stdout if (force_stdout or sys.stdout.isatty()) else sys.stderr
        out.write("---\n")
        out.write(build_startup_yaml(config))
        out.flush()
    except BrokenPipeError:
        return


def _run_text(cmd: List[str], timeout: int = 3) -> str:
    try:
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return (res.stdout or "") + (res.stderr or "")
    except Exception:
        return ""


def list_capture_devices_linux() -> List[Tuple[str, str]]:
    devices: List[Tuple[str, str]] = []
    out = _run_text(["arecord", "-l"], timeout=3)
    cards = {}
    card = None
    for line in out.splitlines():
        line = line.strip()
        if line.startswith("card ") and ":" in line:
            # card 0: PCH [HDA Intel PCH], device 0: ...
            parts = line.split(":", 1)
            card = parts[0].split()[1]
            cards[card] = parts[1].strip()
            dev = None
            if "device" in parts[0]:
                try:
                    dev = parts[0].split("device", 1)[1].strip().split()[0]
                except Exception:
                    dev = None
            if card is not None and dev is not None:
                devices.append((f"plughw:{card},{dev}", f"{cards.get(card, '')}".strip()))
        elif line.startswith("device ") and card is not None:
            try:
                dev = line.split(":", 1)[0].split()[1]
                devices.append((f"plughw:{card},{dev}", f"{cards.get(card, '')}".strip()))
            except Exception:
                pass

    # common logical devices
    devices.insert(0, ("default", "ALSA default"))
    out_l = _run_text(["arecord", "-L"], timeout=3)
    if "pulse" in out_l.split():
        devices.insert(0, ("pulse", "PulseAudio"))

    seen = set()
    uniq: List[Tuple[str, str]] = []
    for d, desc in devices:
        if d in seen:
            continue
        seen.add(d)
        uniq.append((d, desc))
    return uniq


