def tts_from_stdin(shell: "VoiceShell") -> int:
    data = ""
    try:
        data = sys.stdin.read()
    except Exception:
        data = ""

    if data:
        try:
            print(data, end="")
        except BrokenPipeError:
            return 0

    lines = [l.strip() for l in (data or "").splitlines() if l.strip()]
    last = lines[-1] if lines else ""
    if not last:
        return 1

    try:
        shell.speak(last)
    except Exception:
        pass
    return 0


